{
  "manifest_version": 3,
  "name": "FocusRPG",
  "version": "5.0",
  "description": "Gamified productivity tracker with XP, streaks, avatars, and focus tools.",
  "permissions": ["tabs", "storage", "idle"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "chrome_url_overrides": {
    "newtab": "dashboard.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
